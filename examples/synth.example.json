{
  "project": "my-project",

  "settings": {
    "communication_mode": "MESH",
    "auto_approve_tools": [
      "synth-mcp/send_message",
      "synth-mcp/launch_agent",
      "synth-mcp/list_agents"
    ],

    "hooks": {
      "on_agent_startup": {
        "active": true
      },

      "on_agent_join": {
        "active": true,
        "recipients": "parent",
        "template": "Agent \"{agent_id}\" is now active. Task: \"{task}\".",
        "kind": "system"
      },

      "on_agent_exit": {
        "active": true,
        "recipients": "parent",
        "template": "Agent \"{agent_id}\" has left the session.",
        "kind": "system"
      }
    }
  }
}
